<?xml version="1.0"?>
<!-- xMateNB12s industrial standard 6-axis manipulator (12 kg payload, standard wrist) -->
<!-- Kinematics from 仓二 NB12s-1214-H *_mech.cfg (proxy for NB12s-1214-BE ME_AE_SS_xC) + isg/NB12s-1214/param.json -->
<!-- Attention: simplified link inertias for visualization / MoveIt -->

<robot name="xMateNB12s" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="robot_ip" default="192.168.21.10"/>
  <xacro:arg name="local_ip" default="192.168.21.131"/>

  <xacro:include filename="$(find rokae_description)/urdf/materials.xacro"/>
  <xacro:property name="nameofManipulator" value="xMateNB12s"/>

  <!-- Joint limits: JOINT_RANGE_*_CUSTOMIZE from NB12s-1214-H_mech.cfg (deg -> rad) -->
  <xacro:property name="j1_lo" value="-2.9670597283903604"/>
  <xacro:property name="j1_hi" value="2.9670597283903604"/>
  <xacro:property name="j2_lo" value="-1.832595714593849"/>
  <xacro:property name="j2_hi" value="2.530727415390625"/>
  <xacro:property name="j3_lo" value="-3.665191429188092"/>
  <xacro:property name="j3_hi" value="1.2217304763960306"/>
  <xacro:property name="j4_lo" value="-4.71238898038469"/>
  <xacro:property name="j4_hi" value="4.71238898038469"/>
  <xacro:property name="j5_lo" value="-2.356194490192345"/>
  <xacro:property name="j5_hi" value="2.356194490192345"/>
  <xacro:property name="j6_lo" value="-6.283185307179586"/>
  <xacro:property name="j6_hi" value="6.283185307179586"/>

  <!-- JOINT_MAX_SPEED from NB12s-1214-H_mech.cfg MOTION (deg/s -> rad/s) -->
  <xacro:property name="j1_vel" value="3.8920842319473548"/>
  <xacro:property name="j2_vel" value="4.276056667386107"/>
  <xacro:property name="j3_vel" value="5.061454830783555"/>
  <xacro:property name="j4_vel" value="7.592182246175334"/>
  <xacro:property name="j5_vel" value="7.853981633974483"/>
  <xacro:property name="j6_vel" value="12.304571226560023"/>

  <link name="world"/>
  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="${nameofManipulator}_base"/>
  </joint>

  <link name="${nameofManipulator}_base">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="28.5"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0.12"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="${nameofManipulator}_base"/>
    <child link="${nameofManipulator}_link1"/>
    <limit effort="11.0" lower="${j1_lo}" upper="${j1_hi}" velocity="${j1_vel}"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="${nameofManipulator}_link1">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="29.921"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5"/>
      <origin rpy="0 0 0" xyz="0.041 0.031 0.376"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <!-- param.json: joint2 [100, 0, 500] mm, axis Y -->
  <joint name="joint2" type="revolute">
    <parent link="${nameofManipulator}_link1"/>
    <child link="${nameofManipulator}_link2"/>
    <limit effort="14.3" lower="${j2_lo}" upper="${j2_hi}" velocity="${j2_vel}"/>
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0.1 0 0.5"/>
  </joint>

  <link name="${nameofManipulator}_link2">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="13.139"/>
      <inertia ixx="0.3" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.3"/>
      <origin rpy="0 0 0" xyz="0 0.017 0.215"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <!-- param.json: joint3 [0, 0, 680] mm, axis Y -->
  <joint name="joint3" type="revolute">
    <parent link="${nameofManipulator}_link2"/>
    <child link="${nameofManipulator}_link3"/>
    <limit effort="8.36" lower="${j3_lo}" upper="${j3_hi}" velocity="${j3_vel}"/>
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0 0 0.68"/>
  </joint>

  <link name="${nameofManipulator}_link3">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="10.741"/>
      <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.2"/>
      <origin rpy="0 0 0" xyz="0.032 0.007 0.025"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <!-- param.json: joint4 [660, 0, 50] mm, axis X -->
  <joint name="joint4" type="revolute">
    <parent link="${nameofManipulator}_link3"/>
    <child link="${nameofManipulator}_link4"/>
    <limit effort="2.24" lower="${j4_lo}" upper="${j4_hi}" velocity="${j4_vel}"/>
    <axis xyz="1 0 0"/>
    <origin rpy="0 0 0" xyz="0.66 0 0.05"/>
  </joint>

  <link name="${nameofManipulator}_link4">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/${nameofManipulator}_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="2.073"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
      <origin rpy="0 0 0" xyz="-0.264 0.006 0"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/${nameofManipulator}_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="${nameofManipulator}_link4"/>
    <child link="${nameofManipulator}_link5"/>
    <limit effort="2.24" lower="${j5_lo}" upper="${j5_hi}" velocity="${j5_vel}"/>
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="${nameofManipulator}_link5">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="2.073"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      <origin rpy="0 0 0" xyz="0.018 0 0"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <!-- param.json: joint6 [98, 0, 0] mm, axis X -->
  <joint name="joint6" type="revolute">
    <parent link="${nameofManipulator}_link5"/>
    <child link="${nameofManipulator}_link6"/>
    <limit effort="2.24" lower="${j6_lo}" upper="${j6_hi}" velocity="${j6_vel}"/>
    <axis xyz="1 0 0"/>
    <origin rpy="0 0 0" xyz="0.098 0 0"/>
  </joint>

  <link name="${nameofManipulator}_link6">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.415"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
      <origin rpy="0 0 0" xyz="-0.018 0 0"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

</robot>
